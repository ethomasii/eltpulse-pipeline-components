    },
    {
      "key": "dtypes",
      "label": "Dtype mapping",
      "description": "JSON object column → dtype, e.g. {\"amount\":\"float64\",\"created_at\":\"datetime64[ns]\"}",
      "type": "text",
      "required": true
    },
    {
      "key": "output_table",
      "label": "Output table",
      "type": "string"
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
