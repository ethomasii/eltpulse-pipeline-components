{
  "id": "freshness_check",
  "name": "Freshness check",
  "category": "check",
  "description": "Assert table was updated within max lag minutes (SQL post-check).",
  "compileTarget": "quality",
  "fields": [
    {
      "key": "table",
      "label": "Table",
      "type": "string",
      "required": true
    },
    {
      "key": "timestamp_column",
      "label": "Timestamp column",
      "type": "string",
      "required": true,
      "placeholder": "updated_at"
    },
    {
      "key": "max_lag_minutes",
      "label": "Max lag (minutes)",
      "type": "number",
      "default": 1440
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
