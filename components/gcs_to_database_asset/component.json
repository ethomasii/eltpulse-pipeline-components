{
  "id": "gcs_to_database_asset",
  "aliases": [
    "adls_to_database_asset"
  ],
  "name": "GCS / cloud storage ingest",
  "category": "ingestion",
  "description": "Merge GCS/cloud filesystem ingest hints into source configuration.",
  "compileTarget": "dlt",
  "fields": [
    {
      "key": "bucket_url",
      "label": "Bucket URL",
      "description": "gs://bucket/prefix",
      "type": "string",
      "required": true
    },
    {
      "key": "file_glob",
      "label": "File glob",
      "type": "string",
      "default": "**/*"
    },
    {
      "key": "table_name",
      "label": "Destination table name",
      "type": "string"
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
