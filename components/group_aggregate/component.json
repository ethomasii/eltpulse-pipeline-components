{
  "id": "group_aggregate",
  "aliases": [
    "aggregate_table",
    "group_by",
    "summarize",
    "make_group"
  ],
  "name": "Group & aggregate",
  "category": "transformation",
  "description": "Group by columns and compute aggregations (pandas groupby).",
  "compileTarget": "python",
  "fields": [
    {
      "key": "table",
      "label": "Table",
      "type": "string",
      "required": true
    },
    {
      "key": "group_by",
      "label": "Group by columns",
      "type": "string_list",
      "required": true
    },
    {
      "key": "aggregations",
      "label": "Aggregations JSON",
      "description": "e.g. {\"amount\":\"sum\",\"id\":\"count\"}",
      "type": "text",
      "required": true
    },
    {
      "key": "output_table",
      "label": "Output table",
      "type": "string",
      "required": true
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
