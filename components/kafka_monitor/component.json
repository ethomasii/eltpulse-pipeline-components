{
  "id": "kafka_monitor",
  "name": "Kafka lag sensor",
  "category": "sensor",
  "description": "Monitor Kafka consumer lag for a topic.",
  "compileTarget": "monitor",
  "fields": [
    {
      "key": "bootstrap_servers",
      "label": "Bootstrap servers",
      "type": "string",
      "required": true
    },
    {
      "key": "topic",
      "label": "Topic",
      "type": "string",
      "required": true
    },
    {
      "key": "group_id",
      "label": "Consumer group",
      "type": "string",
      "required": true
    },
    {
      "key": "max_lag",
      "label": "Max lag threshold",
      "type": "number",
      "default": 1000
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
