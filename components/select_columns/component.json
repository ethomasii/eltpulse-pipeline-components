{
  "id": "select_columns",
  "name": "Select columns",
  "category": "transformation",
  "description": "Project a subset of columns from a loaded table.",
  "compileTarget": "python",
  "fields": [
    {
      "key": "table",
      "label": "Table",
      "type": "string",
      "required": true
    },
    {
      "key": "columns",
      "label": "Columns",
      "type": "string_list",
      "required": true,
      "placeholder": "id, name, created_at"
    },
    {
      "key": "output_table",
      "label": "Output table",
      "type": "string"
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
