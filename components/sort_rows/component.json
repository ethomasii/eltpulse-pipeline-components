      "required": true
    },
    {
      "key": "ascending",
      "label": "Ascending",
      "description": "true/false or comma list matching columns",
      "type": "string",
      "default": "true"
    },
    {
      "key": "output_table",
      "label": "Output table",
      "type": "string"
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
