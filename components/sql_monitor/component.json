{
  "id": "sql_monitor",
  "name": "SQL watermark sensor",
  "category": "sensor",
  "description": "Monitor SQL table watermark / row count threshold.",
  "compileTarget": "monitor",
  "fields": [
    {
      "key": "table",
      "label": "Table",
      "type": "string",
      "required": true
    },
    {
      "key": "watermark_column",
      "label": "Watermark column",
      "type": "string",
      "required": true
    },
    {
      "key": "min_rows",
      "label": "Min rows expected",
      "type": "number",
      "default": 1
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
