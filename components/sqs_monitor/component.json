{
  "id": "sqs_monitor",
  "name": "SQS sensor",
  "category": "sensor",
  "description": "Monitor SQS queue depth / message arrival.",
  "compileTarget": "monitor",
  "fields": [
    {
      "key": "queue_url",
      "label": "Queue URL",
      "type": "string",
      "required": true
    },
    {
      "key": "threshold",
      "label": "Min messages",
      "type": "number",
      "default": 1
    }
  ],
  "version": 1,
  "runtime": "eltpulse",
  "packageCompile": true,
  "compileArtifact": "compile.mjs"
}
